# Database connection URL for local CLI scripts running outside containers
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sehat_terus

# Backend Server Configuration
PORT=5000
NODE_ENV=development

# Frontend Client Origin (for CORS settings)
FRONTEND_URL=http://localhost:3000

# Groq API key — dipakai POST /api/ai/analyze (ringkasan LLM situasi penyakit)
# dan GET /api/ai/predict-drugs (prediksi kebutuhan obat, admin panel FA7)
GROQ_API_KEY=your_groq_api_key_here
